APP_NAME="Prototipo de Analisis Mamografico"
SECRET_KEY="change-me"
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=storage/uploads

FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
WEB_PORT=5000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mamografias_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
DATABASE_URL=postgresql+psycopg://postgres:1234@localhost:5432/mamografias_db

JULIA_EXECUTABLE=julia
SIMULATOR_PROJECT_PATH=simulator
SIMULATOR_RUN_SCRIPT_PATH=simulator/scripts/run_case.jl
SIMULATION_DEFAULT_SEED=1234
SIMULATION_DEFAULT_STEPS=500
SIMULATION_DEFAULT_DENSITY=0.25
SIMULATION_DEFAULT_N0=10
SIMULATION_DEFAULT_MASS=1
SIMULATION_DEFAULT_KBT=1
SIMULATION_DEFAULT_TAU=1
SIMULATION_DEFAULT_ROTATION_ANGLE=1.5707963267948966
SIMULATION_DEFAULT_REALIZATIONS=3
SIMULATION_DEFAULT_LABELED_PARTICLES=500
SIMULATION_CORRELATION_INITIAL_TIMES=50
SIMULATION_DEFAULT_OUTPUT_TIMES=0,100,500
SIMULATION_GRID_SHIFT_ENABLED=false
# 0, empty, none or unlimited means no max processing time.
SIMULATION_TIMEOUT_SECONDS=0
# Threads de CPU para la simulacion Julia (paraleliza el loop de particulas).
# Acepta un numero o "auto". En la PC de desarrollo: 6 (de 8 cores fisicos) deja la
# maquina usable. En el servidor: subir segun cores disponibles o usar "auto".
SIMULATION_CPU_THREADS=6
# Limite duro de cores que puede usar el contenedor worker (red de seguridad para no
# dejar la maquina inutilizable). Conviene mantenerlo alineado con SIMULATION_CPU_THREADS.
WORKER_CPU_LIMIT=6

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
SIMULATION_QUEUE_NAME=simulation_jobs
