APP_NAME="Prototipo de Analisis Mamografico"
PUBLIC_BASE_URL=http://127.0.0.1:5000
SECRET_KEY="change-me"
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=storage/uploads

FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
WEB_PORT=5000
# Gunicorn se usa al ejecutar la imagen Docker. PORT lo asigna el proveedor web.
PORT=5000
WEB_WORKERS=2
WEB_THREADS=4
WEB_REQUEST_TIMEOUT_SECONDS=120
WEB_GRACEFUL_TIMEOUT_SECONDS=30
WEB_WORKER_TMP_DIR=/dev/shm

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mamografias_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
# Neon y otros proveedores pueden entregar postgresql://; la aplicacion lo
# normaliza automaticamente al controlador psycopg 3 y conserva parametros TLS.
DATABASE_URL=postgresql+psycopg://postgres:1234@localhost:5432/mamografias_db
DATABASE_POOL_RECYCLE_SECONDS=300

# Almacenamiento. En desarrollo se conserva el disco local. En produccion,
# STORAGE_BACKEND=r2 usa un bucket privado compatible con la API S3.
STORAGE_BACKEND=local
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PRESIGNED_URL_TTL_SECONDS=300

JULIA_EXECUTABLE=julia
SIMULATOR_PROJECT_PATH=simulator
SIMULATOR_RUN_SCRIPT_PATH=simulator/scripts/run_case.jl
SIMULATION_DEFAULT_SEED=1234
SIMULATION_DEFAULT_STEPS=100
SIMULATION_DEFAULT_N0=10
SIMULATION_DEFAULT_MASS=1
SIMULATION_DEFAULT_KBT=1
SIMULATION_DEFAULT_TAU=1
SIMULATION_DEFAULT_ROTATION_ANGLE=1.5707963267948966
SIMULATION_DEFAULT_REALIZATIONS=3
SIMULATION_DEFAULT_LABELED_PARTICLES=500
SIMULATION_CORRELATION_INITIAL_TIMES=50
SIMULATION_DEFAULT_OUTPUT_TIMES=0,100
SIMULATION_GRID_SHIFT_ENABLED=false
# 0, empty, none or unlimited means no max processing time.
SIMULATION_TIMEOUT_SECONDS=0
# Threads de CPU para la simulacion Julia (paraleliza el loop de particulas).
# Acepta un numero o "auto". En la PC de desarrollo: 6 (de 8 cores fisicos) deja la
# maquina usable. En el servidor universitario se configura en 30.
SIMULATION_CPU_THREADS=6
# Limite duro de cores que puede usar el contenedor worker (red de seguridad para no
# dejar la maquina inutilizable). Conviene mantenerlo alineado con SIMULATION_CPU_THREADS.
WORKER_CPU_LIMIT=6

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
# En Upstash se debe usar la URL completa rediss:// para habilitar TLS.
SIMULATION_QUEUE_NAME=simulation_jobs

# Envio de correo (recuperacion de contraseña y futuros avisos).
# MAIL_BACKEND=console -> escribe el correo en el log; no envia nada real ni
#   necesita credenciales. Ideal para desarrollo y demos.
# MAIL_BACKEND=smtp -> envia de verdad via un servidor SMTP (p. ej. una cuenta
#   de Gmail dedicada al prototipo). Solo entonces hacen falta las MAIL_SMTP_*.
MAIL_BACKEND=console
# Para Gmail: MAIL_SMTP_HOST=smtp.gmail.com, MAIL_SMTP_PORT=587, TLS=true,
# usuario = la cuenta dedicada, password = una "app password" de 16 letras.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=true
# Remitente de los correos. Si se deja vacio, se usa MAIL_SMTP_USERNAME.
# Ejemplo: Prototipo Mamografico <correo-del-prototipo@gmail.com>
MAIL_SENDER=
# API HTTPS de Brevo para produccion. MAIL_BACKEND=brevo activa este backend;
# BREVO_SENDER_EMAIL debe corresponder a un remitente verificado en Brevo.
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_API_KEY=
BREVO_SENDER_NAME=Prototipo Mamografico
BREVO_SENDER_EMAIL=
# Validez del enlace de recuperacion en segundos (3600 = 1 hora).
PASSWORD_RESET_TOKEN_MAX_AGE=3600
