# Copiar como .env.production fuera del repositorio y completar los secretos.
# Nunca confirmar el archivo real en Git.
APP_NAME=Prototipo Mamografico
PUBLIC_BASE_URL=https://example.invalid
SECRET_KEY=replace-with-a-long-random-value
MAX_CONTENT_LENGTH=52428800

DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_POOL_RECYCLE_SECONDS=300

REDIS_URL=rediss://default:password@host:6379
SIMULATION_QUEUE_NAME=simulation_jobs

STORAGE_BACKEND=r2
R2_BUCKET_NAME=replace-with-private-bucket
R2_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-access-key
R2_SECRET_ACCESS_KEY=replace-with-secret-key
R2_REGION=auto
R2_PRESIGNED_URL_TTL_SECONDS=300

MAIL_BACKEND=brevo
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_NAME=Prototipo Mamografico
BREVO_SENDER_EMAIL=replace-with-verified-sender
PASSWORD_RESET_TOKEN_MAX_AGE=3600

PORT=5000
WEB_WORKERS=2
WEB_THREADS=4
WEB_REQUEST_TIMEOUT_SECONDS=120
WEB_GRACEFUL_TIMEOUT_SECONDS=30
WEB_WORKER_TMP_DIR=/dev/shm

SIMULATION_DEFAULT_SEED=1234
SIMULATION_DEFAULT_STEPS=200
SIMULATION_DEFAULT_N0=10
SIMULATION_DEFAULT_MASS=1
SIMULATION_DEFAULT_KBT=1
SIMULATION_DEFAULT_TAU=1
SIMULATION_DEFAULT_ROTATION_ANGLE=1.5707963267948966
SIMULATION_DEFAULT_REALIZATIONS=3
SIMULATION_DEFAULT_LABELED_PARTICLES=500
SIMULATION_CORRELATION_INITIAL_TIMES=50
SIMULATION_DEFAULT_OUTPUT_TIMES=0,200
SIMULATION_GRID_SHIFT_ENABLED=false
SIMULATION_TIMEOUT_SECONDS=0
SIMULATION_CPU_THREADS=30
WORKER_CPU_LIMIT=30
